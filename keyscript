-- Hàm kiểm tra và xử lý key
local function ProcessKey(key, source)
    if not key then return false end
    
    -- Kiểm tra key có khớp device không
    if not ValidateKeyWithDevice(key) then
        -- Thử lấy lại Device ID từ web
        local newDeviceId = GetDeviceIdFromWeb()
        if newDeviceId then
            DeviceId = newDeviceId
            if ValidateKeyWithDevice(key) then
                SaveKey(key)
                ExecuteMainScript()
                return true
            end
        end
        
        -- Kiểm tra xem key có đang được dùng trên thiết bị khác không
        if CheckKeyUsage(key) then
            KickPlayer("❌ Key này đang được sử dụng trên thiết bị khác!\nVui lòng tạo key mới trên web.")
        else
            KickPlayer("❌ Key không khớp với thiết bị này!\nDevice ID của bạn: " .. DeviceId)
        end
        return false
    end
    
    -- Key hợp lệ
    SaveKey(key)
    ExecuteMainScript()
    return true
end

-- Ưu tiên key từ web
if webKey then
