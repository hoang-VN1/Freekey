-- === LẤY DEVICE ID TỪ WEB (ĐỒNG BỘ VỚI HTML) ===
local function GetDeviceIdFromWeb()
    local success, html = pcall(function()
        return game:HttpGet(KeySource_URL)
    end)
    if success and html then
        -- Tìm Device ID trong HTML
        local deviceMatch = string.match(html, "Device ID: ([^<]+)")
        if deviceMatch then
            deviceMatch = string.gsub(deviceMatch, "%s+", "")
            return deviceMatch
        end
        
        -- Tìm Device ID trong div #deviceIdDisplay
        local divMatch = string.match(html, 'id="deviceIdDisplay">([^<]+)</div>')
        if divMatch then
            divMatch = string.gsub(divMatch, "%s+", "")
            divMatch = string.match(divMatch, "DEV_[A-Z0-9]+")
            if divMatch then
                return divMatch
            end
        end
    end
    return nil
end

-- === TẠO DEVICE ID DỰ PHÒNG ===
local function GenerateFallbackDeviceId()
    local components = {
        game:GetService("UserSettings"):GetService("UserGameSettings").GamepadEnabled,
        game:GetService("UserSettings"):GetService("UserGameSettings").MouseSensitivity,
        game:GetService("UserSettings"):GetService("UserGameSettings").CameraMode,
        game:GetService("GuiService"):GetScreenSize().X,
        game:GetService("GuiService"):GetScreenSize().Y,
        game:GetService("RunService"):IsStudio(),
        game:GetService("RunService"):IsServer(),
        game:GetService("RunService"):IsClient(),
        os.time(),
        math.random()
    }
    
    local str = table.concat(components, "|")
    local hash = 0
    for i = 1, #str do
        hash = (hash * 31 + string.byte(str, i)) % 2^32
    end
    
    return "DEV_" .. string.format("%08X", math.abs(hash))
end

-- === LẤY DEVICE ID (ƯU TIÊN TỪ WEB) ===
local DeviceId = GetDeviceIdFromWeb()
if not DeviceId then
    DeviceId = GenerateFallbackDeviceId()
end

-- === LẤY KEY TỪ WEB ===
local function FetchKeyFromWeb()
    local success, html = pcall(function()
        return game:HttpGet(KeySource_URL)
    end)
    if not success or not html then
        return nil
    end
    
    -- Tìm key trong HTML (định dạng: HOANG_XXXXXXXX_DEV_XXXXXXXX)
    local keyMatch = string.match(html, "HOANG_[A-Z0-9]+_DEV_[A-Z0-9]+")
    if keyMatch then
        return keyMatch
    end
    
    -- Tìm key trong div #accessKey
    local divMatch = string.match(html, 'id="accessKey">([^<]+)</div>')
    if divMatch then
        divMatch = string.gsub(divMatch, "%s+", "")
        if string.find(divMatch, Prefix) then
            return divMatch
        end
    end
    
    return nil
end

-- === KIỂM TRA KEY CÓ KHỚP DEVICE KHÔNG ===
local function ValidateKeyWithDevice(key)
    if not key then return false end
    
    local parts = {}
    for part in string.gmatch(key, "[^_]+") do
        table.insert(parts, part)
    end
    
    if #parts ~= 3 then return false end
    if parts[1] ~= Prefix then return false end
    if parts[3] ~= DeviceId then return false end
    
    return true
end

-- === LẤY KEY ĐÃ LƯU ===
local function GetSavedKey()
    if readfile and isfile and isfile(File_Name) then
        local saved = readfile(File_Name)
        if saved and saved ~= "" then
            return saved
        end
    end
    return nil
end

-- === LƯU KEY ===
local function SaveKey(key)
    if writefile then
        pcall(function() writefile(File_Name, key) end)
    end
end

-- === KICK NGƯỜI CHƠI ===
local function KickPlayer(reason)
    local player = Players.LocalPlayer
    if player then
        player:Kick(reason or "⚠️ Key không hợp lệ hoặc không khớp với thiết bị!")
    end
end

-- === KIỂM TRA KEY CÒN HẠN (DỰA TRÊN EXPIRY TỪ WEB) ===
local function CheckKeyExpiry()
    local success, html = pcall(function()
        return game:HttpGet(KeySource_URL)
    end)
    if success and html then
        local expiryMatch = string.match(html, "Hết hạn sau:.-(%d+) ngày (%d+):(%d+):(%d+)")
        if expiryMatch then
            local days, hours, minutes, seconds = tonumber(expiryMatch)
            if days and hours and minutes and seconds then
                return days > 0 or hours > 0 or minutes > 0 or seconds > 0
            end
        end
    end
    return true
end

-- === KIỂM TRA KEY ĐANG ĐƯỢC SỬ DỤNG TRÊN THIẾT BỊ KHÁC ===
local function CheckKeyUsage(key)
    if not key then return false end
    
    -- Lấy Device ID từ key
    local parts = {}
    for part in string.gmatch(key, "[^_]+") do
        table.insert(parts, part)
    end
    if #parts ~= 3 then return false end
    
    local keyDeviceId = parts[3]
    
    -- Kiểm tra xem key có đang được lưu trên thiết bị khác không
    -- Bằng cách so sánh với Device ID hiện tại
    if keyDeviceId ~= DeviceId then
        return true -- Key đang được sử dụng trên thiết bị khác
    end
    
    return false
end

